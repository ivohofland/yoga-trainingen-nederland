node_modules/
.env
.next/
out/
*.tsbuildinfo
next-env.d.ts
.DS_Store

# Regenerated on every build with a NEW sha and a NEW timestamp, by design (its whole job
# is stating which commit and moment produced the CURRENT out/, per export-json.ts) — unlike
# public/data/v1/providers.json, a committed copy of this one could never describe the commit
# it is part of: the instant it is committed, the sha inside it names a PARENT commit, not
# HEAD. Committing it would also mean a diff on every single build regardless of whether the
# data changed. It exists only to be written into public/, copied into out/ by `next build`,
# and read live at /build-info.json.
public/build-info.json

# Generated at build from content/notities/*.md by scripts/build-feed.ts, then
# copied into out/ by next build. Like public/build-info.json above, a committed
# copy could go stale against the posts; it is regenerated every build.
public/notities/feed.xml

# Archive BODIES are not published — see data/archives/README.md.
# The .sha256 next to each one IS published, and proves the snapshot exists
# and has not been altered, without republishing a provider's copyrighted page.
# Bodies live on disk and in the private, git-dated archive repo.
#
# DENY BY DEFAULT. This used to name the two extensions we happened to write
# (*.pdf, *.html) — an allowlist by omission, which publishes any capture format
# nobody thought of. The archiver already writes others: a directly-downloaded
# brochure keeps the URL's own extension, and the page.pdf() fallback is a
# full-page .png. Both would have been committed to a public repo, which is the
# one thing this file exists to prevent. So: ignore EVERYTHING under
# data/archives, then re-admit only what we mean to publish.
data/archives/**
!data/archives/**/
!data/archives/**/*.sha256
!data/archives/README.md
!data/archives/wayback-todo.md
